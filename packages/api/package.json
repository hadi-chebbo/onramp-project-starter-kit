{
  "name": "@starter-kit/api",
  "version": "0.0.1",
  "private": true,
  "main": "./server.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.js --coverage --passWithNoTests",
    "lint": "eslint 'src/**/*.ts' 'app.ts' 'server.ts'",
    "clean": "rm -rf dist",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@starter-kit/shared": "*",
    "@types/cookie-parser": "^1.4.10",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^5.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
